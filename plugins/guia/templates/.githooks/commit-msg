#!/bin/sh
# Git hook commit-msg - valida travas em features/registry.yaml.
#
# Repo-mae (clone do pack): usa core/lock/check-lock.py.
#     git config core.hooksPath core/hooks
# Consumidor (plugin global): usa o check-lock.py do plugin via
# ${CLAUDE_PLUGIN_ROOT}, resolvido quando o commit roda dentro de uma
# sessao Claude Code. Instalado por:
#     /guia:init   (configura core.hooksPath .githooks)

ROOT="$(git rev-parse --show-toplevel)"

# Procura Python que efetivamente roda (filtra o stub do Microsoft Store no
# Windows, que aparece no PATH mas falha ao invocar --version).
PY=""
for cmd in python3 python py; do
    if command -v "$cmd" >/dev/null 2>&1 && "$cmd" --version >/dev/null 2>&1; then
        PY="$cmd"
        break
    fi
done

if [ -z "$PY" ]; then
    echo "Erro: Python nao encontrado no PATH. Hook abortado." >&2
    exit 2
fi

# Localiza o validador de locks. Ordem: repo-mae (core/lock) primeiro,
# depois o plugin global instalado (CLAUDE_PLUGIN_ROOT, setado quando o
# commit roda dentro de uma sessao Claude Code).
CHECK=""
if [ -f "$ROOT/core/lock/check-lock.py" ]; then
    CHECK="$ROOT/core/lock/check-lock.py"
elif [ -n "$CLAUDE_PLUGIN_ROOT" ] && [ -f "$CLAUDE_PLUGIN_ROOT/bin/check-lock.py" ]; then
    CHECK="$CLAUDE_PLUGIN_ROOT/bin/check-lock.py"
fi

if [ -z "$CHECK" ]; then
    echo "Guia Fluxo: validador de locks nao encontrado (core/lock ou \$CLAUDE_PLUGIN_ROOT/bin)." >&2
    echo "Guia Fluxo: commit liberado SEM checagem de lock. Rode /guia:init apos atualizar o plugin." >&2
    exit 0
fi

# GUIA_PROJECT_ROOT faz o lock_api do plugin mirar o registry deste repo
# (e nao o do diretorio do plugin). Inofensivo no repo-mae (mesmo valor).
exec env GUIA_PROJECT_ROOT="$ROOT" "$PY" "$CHECK" hook "$1"
