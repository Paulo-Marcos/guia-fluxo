#!/bin/sh
# Git hook commit-msg - valida travas em features/registry.yaml.
# Instale uma vez por clone:
#     git config core.hooksPath core/hooks

ROOT="$(git rev-parse --show-toplevel)"

# Procura Python que efetivamente roda (filtra o stub do Microsoft Store no
# Windows, que aparece no PATH mas falha ao invocar --version).
PY=""
for cmd in python3 python py; do
    if command -v "$cmd" >/dev/null 2>&1 && "$cmd" --version >/dev/null 2>&1; then
        PY="$cmd"
        break
    fi
done

if [ -z "$PY" ]; then
    echo "Erro: Python nao encontrado no PATH. Hook abortado." >&2
    exit 2
fi

exec "$PY" "$ROOT/core/lock/check-lock.py" hook "$1"
